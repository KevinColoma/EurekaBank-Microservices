<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:id="@+id/main"
    android:layout_height="match_parent"
    android:background="@color/color_gris"
    tools:context="vista.DepositoActivity" >

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header con color principal -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="0dp"
            app:cardElevation="4dp"
            app:cardBackgroundColor="@color/color_verde">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp"
                android:gravity="center">

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Realizar Operación"
                    android:textSize="24sp"
                    android:textStyle="bold"
                    android:gravity="center"
                    android:textColor="@color/white" />

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Contenido scrollable -->
        <ScrollView
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <!-- Card para seleccionar operación -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <TextView
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:text="Seleccione operación"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/color_azul"
                            android:layout_marginBottom="8dp" />

                        <Spinner
                            android:id="@+id/spinnerOperacion"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:entries="@array/operaciones" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card para datos de la operación -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Campo de cuenta -->
                        <EditText
                            android:id="@+id/txtCuenta"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="Número de cuenta"
                            android:inputType="text"
                            android:padding="12dp"
                            android:background="@drawable/edittext_style"
                            android:layout_marginBottom="12dp"
                            android:textColor="@color/black"
                            android:textColorHint="@color/color_gris_oscuro" />

                        <!-- Campo de importe -->
                        <EditText
                            android:id="@+id/txtImporte"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="Importe"
                            android:inputType="numberDecimal"
                            android:padding="12dp"
                            android:background="@drawable/edittext_style"
                            android:layout_marginBottom="12dp"
                            android:textColor="@color/black"
                            android:textColorHint="@color/color_gris_oscuro" />

                        <!-- Campo de cuenta origen (para transferencia) -->
                        <EditText
                            android:id="@+id/txtCuentaOrigen"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="Cuenta Origen"
                            android:inputType="text"
                            android:padding="12dp"
                            android:background="@drawable/edittext_style"
                            android:layout_marginBottom="12dp"
                            android:visibility="gone"
                            android:textColor="@color/black"
                            android:textColorHint="@color/color_gris_oscuro" />

                        <!-- Campo de cuenta destino (para transferencia) -->
                        <EditText
                            android:id="@+id/txtCuentaDestino"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:hint="Cuenta Destino"
                            android:inputType="text"
                            android:padding="12dp"
                            android:background="@drawable/edittext_style"
                            android:visibility="gone"
                            android:textColor="@color/black"
                            android:textColorHint="@color/color_gris_oscuro" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- Card para botones de acción -->
                <androidx.cardview.widget.CardView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="16dp"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="4dp"
                    app:cardBackgroundColor="@color/white">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="16dp">

                        <!-- Botón para procesar -->
                        <Button
                            android:id="@+id/btnProcesar"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="Procesar"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/color_verde"
                            android:layout_marginBottom="12dp" />

                        <!-- Botón para regresar -->
                        <Button
                            android:id="@+id/btnRegresar"
                            android:layout_width="match_parent"
                            android:layout_height="48dp"
                            android:text="Regresar"
                            android:textSize="16sp"
                            android:textStyle="bold"
                            android:textColor="@color/white"
                            android:backgroundTint="@color/color_error" />

                    </LinearLayout>
                </androidx.cardview.widget.CardView>

                <!-- ProgressBar -->
                <ProgressBar
                    android:id="@+id/progressBar"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="center_horizontal"
                    android:layout_marginTop="16dp"
                    android:visibility="gone" />

            </LinearLayout>
        </ScrollView>

    </LinearLayout>
</FrameLayout>
