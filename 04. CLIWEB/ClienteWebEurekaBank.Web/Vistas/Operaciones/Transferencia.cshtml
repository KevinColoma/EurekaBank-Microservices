@model TransferenciaViewModel
@{
    ViewData["Title"] = "Transferencias";
}

<div class="row justify-content-center">
    <div class="col-12 col-lg-8">
        <div class="card border-0 shadow-sm" style="border-left: 4px solid #95bf5a;">
            <div class="card-body p-4">
                <div class="d-flex align-items-start justify-content-between gap-3">
                    <div>
                        <h1 class="h5 mb-1 fw-semibold" style="color: #2661a9;">Registrar transferencia</h1>
                        <div class="text-muted small">Se ejecutará un cargo a origen y abono a destino</div>
                    </div>
                </div>

                <form asp-action="Transferencia" method="post" class="mt-3" data-activar-spinner="true" novalidate>
                    @Html.AntiForgeryToken()
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                    <div class="row g-3">
                        <div class="col-12 col-md-4">
                            <label asp-for="CuentaOrigen" class="form-label fw-semibold"></label>
                            <input asp-for="CuentaOrigen" class="form-control" maxlength="8" style="border-color: #2661a9; border-width: 1px;" />
                            <span asp-validation-for="CuentaOrigen" class="text-danger small"></span>
                        </div>
                        <div class="col-12 col-md-4">
                            <label asp-for="CuentaDestino" class="form-label fw-semibold"></label>
                            <input asp-for="CuentaDestino" class="form-control" maxlength="8" style="border-color: #2661a9; border-width: 1px;" />
                            <span asp-validation-for="CuentaDestino" class="text-danger small"></span>
                        </div>
                        <div class="col-12 col-md-4">
                            <label asp-for="Importe" class="form-label fw-semibold"></label>
                            <input asp-for="Importe" class="form-control" inputmode="decimal" style="border-color: #2661a9; border-width: 1px;" />
                            <span asp-validation-for="Importe" class="text-danger small"></span>
                        </div>
                    </div>

                    <div class="d-flex gap-2 mt-4">
                        <button type="submit" class="btn" style="background: linear-gradient(135deg, #95bf5a 0%, #7da84d 100%); color: white; border: none;" data-boton-spinner>
                            <span class="texto-normal">Registrar</span>
                            <span class="texto-cargando d-none">
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                Enviando...
                            </span>
                        </button>
                        <a class="btn btn-outline-primary" style="color: #2661a9; border-color: #2661a9; border-width: 2px;" asp-controller="Panel" asp-action="Index">Volver</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
