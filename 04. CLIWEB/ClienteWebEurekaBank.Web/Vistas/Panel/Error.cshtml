@model ErrorViewModel
@{
    ViewData["Title"] = "Error";
}

<div class="alert" style="background-color: rgba(220, 53, 69, 0.1); border: 2px solid #dc3545; color: #721c24; border-radius: 8px;" role="alert">
    <div class="fw-semibold mb-1" style="color: #2661a9;">⚠️ Ocurrió un error</div>
    <div class="small">No se pudo procesar la solicitud.</div>
    @if (Model.ShowRequestId)
    {
        <div class="small text-muted mt-2">Id de solicitud: <code>@Model.RequestId</code></div>
    }
</div>
