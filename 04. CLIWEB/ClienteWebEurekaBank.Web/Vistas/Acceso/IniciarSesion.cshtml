@model LoginViewModel
@{
    ViewData["Title"] = "Iniciar sesión";
}

<div class="login-container" style="background-image: url('/images/monsterFont.jpg'); background-size: cover; background-position: center; background-attachment: fixed;">
    <div class="login-overlay"></div>
    <div class="row justify-content-center align-items-center min-vh-100">
        <div class="col-12 col-md-8 col-lg-5">
            <div class="card shadow-lg border-0">
                <div class="card-body p-4 p-md-5">
                    <div class="mb-4 text-center">
                        <h1 class="h3 mb-2 fw-bold" style="color: var(--color-principal-azul);">EurekaBank</h1>
                        <div class="text-muted">Accede con tus credenciales</div>
                    </div>

                    <form asp-action="IniciarSesion" method="post" data-activar-spinner="true" novalidate>
                        @Html.AntiForgeryToken()

                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Usuario" class="form-label fw-semibold"></label>
                            <input asp-for="Usuario" class="form-control form-control-lg" autocomplete="username" style="border-color: var(--color-principal-azul); border-width: 2px;" />
                            <span asp-validation-for="Usuario" class="text-danger small"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Password" class="form-label fw-semibold"></label>
                            <input asp-for="Password" class="form-control form-control-lg" autocomplete="current-password" style="border-color: var(--color-principal-azul); border-width: 2px;" />
                            <span asp-validation-for="Password" class="text-danger small"></span>
                        </div>

                        <button type="submit" class="btn btn-dark w-100 btn-lg mb-3" style="background: linear-gradient(135deg, var(--color-principal-azul) 0%, #1a4478 100%); border: none;" data-boton-spinner>
                            <span class="texto-normal">Ingresar</span>
                            <span class="texto-cargando d-none">
                                <span class="spinner-border spinner-border-sm me-2" role="status" aria-hidden="true"></span>
                                Validando...
                            </span>
                        </button>
                    </form>

                    <hr class="my-3" />

                    <div class="small text-muted text-center">
                        La URL de la API se configura en <code>appsettings.json</code>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .login-container {
        position: relative;
        width: 100%;
        min-height: 100vh;
    }

    .login-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        background-color: rgba(0, 0, 0, 0.5);
        z-index: 1;
    }

    .login-container .row {
        position: relative;
        z-index: 2;
    }
</style>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
