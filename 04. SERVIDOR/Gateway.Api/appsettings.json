{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "Kestrel": {
    "Endpoints": {
      "Http": {
        "Url": "http://*:5069"
      }
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "auth": {
        "ClusterId": "auth",
        "Match": {
          "Path": "/Eureka/validar-usuario"
        }
      },
      "movimientos": {
        "ClusterId": "movimientos",
        "Match": {
          "Path": "/Eureka/movimientos/{**resto}"
        }
      },
      "deposito": {
        "ClusterId": "operaciones",
        "Match": {
          "Path": "/Eureka/deposito"
        }
      },
      "retiro": {
        "ClusterId": "operaciones",
        "Match": {
          "Path": "/Eureka/retiro"
        }
      },
      "transferencia": {
        "ClusterId": "transferencia",
        "Match": {
          "Path": "/Eureka/transferencia"
        }
      }
    },
    "Clusters": {
      "auth": {
        "Destinations": {
          "principal": {
            "Address": "http://localhost:5171/"
          }
        }
      },
      "movimientos": {
        "Destinations": {
          "principal": {
            "Address": "http://localhost:5172/"
          }
        }
      },
      "operaciones": {
        "Destinations": {
          "principal": {
            "Address": "http://localhost:5173/"
          }
        }
      },
      "transferencia": {
        "Destinations": {
          "principal": {
            "Address": "http://localhost:5174/"
          }
        }
      }
    }
  }
}
