# Plantilla de variables de entorno del servidor EurekaBank.
# Copia este archivo como .env y completa con tus valores reales.
# El archivo .env NO debe subirse a git.

# Cadena de conexión a la base de datos SQL Server.
EUREKA_DB_CONNECTION=Server=TU_SERVIDOR,1433; Database=TU_BASE; User Id=TU_USUARIO; Password=TU_PASSWORD; TrustServerCertificate=True; Encrypt=True;
